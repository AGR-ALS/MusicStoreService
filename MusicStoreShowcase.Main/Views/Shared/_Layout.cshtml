<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
</head>
<body>
<header class="sticky-top bg-white border-bottom shadow-sm" style="z-index: 1020;">
    <div class="container py-3">
        <div class="toolbar">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label for="localeSelect" class="form-label">Language</label>
                    <select id="localeSelect" class="form-select">
                        <option value="en" selected>English (USA)</option>ф
                        <option value="de">German (Germany)</option>
                    </select>
                </div>
                <div class="col-12 col-md-4">
                    <label for="seedInput" class="form-label">Seed</label>
                    <div class="input-group">
                        <input id="seedInput" type="text" inputmode="numeric" class="form-control" maxlength="20" value="12345">
                        <button id="randomSeedButton" class="btn btn-outline-secondary" type="button" title="Generate random seed">
                            <i class="bi bi-shuffle"></i>
                        </button>
                    </div>
                </div>
                <div class="col-12 col-md-3">
                    <label for="likesInput" class="form-label">Likes</label>
                    <input id="likesInput" type="number" min="0" max="10" step="0.1" class="form-control" value="5.0">
                </div>
                <div class="col-12 col-md-2">
                    <label class="form-label">View</label>
                    <div class="btn-group w-100" role="group">
                        <input type="radio" class="btn-check" name="displayMode" id="tableMode" value="table" checked>
                        <label class="btn btn-outline-primary" for="tableMode"><i class="bi bi-table"></i> Table</label>
                        <input type="radio" class="btn-check" name="displayMode" id="galleryMode" value="gallery">
                        <label class="btn btn-outline-primary" for="galleryMode"><i class="bi bi-grid-3x3-gap"></i> Gallery</label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</header>

<div class="container mt-3">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
